{
  "version": 2,
  "public": true,
  "name": "silentbridge-web",
  "rewrites": [
    {
      "source": "/(status|video_feed)",
      "destination": "http://localhost:5000/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ]
}
