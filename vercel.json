{
  "version": 2,
  "name": "silentbridge-web",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/status",
      "destination": "http://localhost:5000/status"
    },
    {
      "source": "/video_feed",
      "destination": "http://localhost:5000/video_feed"
    },
    { "handle": "filesystem" },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
